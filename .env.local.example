# ── Neon PostgreSQL ───────────────────────────────────────────
# 1. Go to console.neon.tech
# 2. Create project → Dashboard → Connection string → copy it
# It looks like: postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# ── NextAuth ──────────────────────────────────────────────────
# Generate secret: run this in terminal → openssl rand -base64 32
NEXTAUTH_SECRET=your-generated-secret-here
NEXTAUTH_URL=http://localhost:3000

# ── OpenAI ────────────────────────────────────────────────────
# Get from: platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ── App URL ───────────────────────────────────────────────────
# Local: http://localhost:3000
# Production (Vercel): https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
